# 后端环境变量 (部署到 Railway 时在控制台设置)
# 复制此文件为 .env 并填入实际值

# MongoDB Atlas 连接串 (如不设置则使用内存存储)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/mall-kanban

# JWT 密钥 (生产环境请使用随机字符串)
JWT_SECRET=mall-kanban-prod-secret-2026

# 前端地址 (用于 CORS 白名单)
FRONTEND_URL=https://your-vercel-app.vercel.app

# 端口 (Railway 自动设置，本地默认3001)
PORT=3001
